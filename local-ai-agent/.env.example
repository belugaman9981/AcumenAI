# AcumenAI Environment Configuration
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# ── GitHub (optional) ─────────────────────────────────────────────────────────
# Add a Personal Access Token for 5,000 req/hr instead of 60 req/hr
# Create one at: https://github.com/settings/tokens (no scopes needed for public repos)
GITHUB_TOKEN=

# ── Agent behaviour ───────────────────────────────────────────────────────────
# MAX_TOOL_CALLS=10
# REQUEST_TIMEOUT=30
# MAX_SCRAPE_CHARS=6000

# ── Background crawler ────────────────────────────────────────────────────────
# CRAWLER_SLEEP_SECONDS=300
# CRAWLER_MAX_REPOS=20
# MIN_STARS=1000

# ── Brain ─────────────────────────────────────────────────────────────────────
# DEFAULT_BRAIN_POPULATION=48
# RESPONSE_WORD_COUNT=150
# WORD_MAP_TOP_N=20

# ── Display ───────────────────────────────────────────────────────────────────
# SHOW_TOOL_CALLS=true
# SHOW_THOUGHTS=true
